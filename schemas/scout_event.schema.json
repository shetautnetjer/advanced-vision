{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://advanced-vision.local/schemas/scout_event.schema.json",
  "title": "Scout Event",
  "description": "Event emitted by Eagle2-2B scout after fast visual classification. Represents the first filter layer between raw capture and downstream review.",
  "type": "object",
  "required": ["event_id", "timestamp", "scout_version", "classification", "confidence"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "scout_version": {
      "type": "string",
      "description": "Model version identifier (e.g., 'eagle2-2b-v1.0')"
    },
    "inference_time_ms": {
      "type": "integer",
      "description": "Time taken for Eagle inference"
    },
    "classification": {
      "type": "string",
      "enum": [
        "cursor_noise",
        "benign_ui_change",
        "meaningful_ui_change",
        "modal_dialog",
        "form_interaction",
        "chart_update",
        "ticket_update",
        "alert_condition",
        "unknown_significant",
        "requires_review"
      ],
      "description": "Scout's classification of visual change"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Scout confidence in classification"
    },
    "roi_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of ROIs isolated"
    },
    "motion_metrics": {
      "type": "object",
      "properties": {
        "cursor_only": { "type": "boolean" },
        "motion_pixels": { "type": "integer" },
        "motion_percentage": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "escalation_recommended": {
      "type": "boolean",
      "description": "Whether scout recommends escalating to reviewer layer"
    },
    "escalation_reason": {
      "type": "string",
      "enum": ["high_confidence_change", "ambiguous", "risk_indicator", "low_confidence", "none"]
    },
    "artifact_refs": {
      "type": "object",
      "properties": {
        "input_frame": { "type": "string" },
        "output_rois": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
