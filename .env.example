# Moonshot AI API Configuration
# Get your API key from: https://platform.moonshot.cn/

KIMI_API_KEY=your_api_key_here

# Optional: API base URL (default is Moonshot's platform)
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional: Model to use for frame-based video understanding
# Use an image/vision-capable model here.
# KIMI_MODEL=kimi-k2-5

# Display for screen recording (usually :1 for X11)
DISPLAY=:1